@model ERP.ViewModels.Assest.AssestUserPageViewModel
@using Kendo.Mvc.UI

<div class="container-fluid mt-5" dir="rtl">
    @Html.AntiForgeryToken()

    <div id="alertContainer" class="mb-4"></div>

    <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
        <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 2rem;">
            <h3 class="mb-0 fw-bold">
                <i class="fas fa-users me-2"></i>مدیریت مالکین اموال
            </h3>
        </div>

        <div class="card-body p-4">
            <!-- فرم ثبت -->
            <div class="row mb-4 g-3">
                <div class="col-md-3">
                    <label class="form-label fw-bold">نام</label>
                    <input type="text" id="Name" autocomplete="off" class="form-control" placeholder="نام" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">نام خانوادگی</label>
                    <input type="text" id="Family" autocomplete="off" class="form-control" placeholder="خانوادگی" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">نوع</label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="AssestUserTypes" id="typeUser" value="0" checked>
                        <label class="btn btn-outline-primary btn-sm" for="typeUser">کاربر</label>
                        <input type="radio" class="btn-check" name="AssestUserTypes" id="typeUnit" value="1">
                        <label class="btn btn-outline-primary btn-sm" for="typeUnit">واحد</label>
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="button" id="btnRegister" class="btn btn-success w-100">
                        <i class="fas fa-plus me-2"></i>ثبت
                    </button>
                </div>
            </div>

            <!-- GRID -->
            @(Html.Kendo().Grid<ERP.ViewModels.Assest.AssestUserViewModel>()
                        .Name("assestUserGrid")
                        .Columns(columns =>
                        {
                            columns.Bound(c => c.Name).Title("نام").Width("12%").HtmlAttributes(new { style = "text-align:center;" });
                            columns.Bound(c => c.Family).Title("خانوادگی").Width("12%").HtmlAttributes(new { style = "text-align:center;" });
                            columns.Bound(c => c.AssestUserTypes).Title("نوع").Width("10%").ClientTemplate("#= AssestUserTypes == 0 ? 'کاربر' : 'واحد' #").HtmlAttributes(new { style = "text-align:center;" });
                            columns.Bound(c => c.IsActive).Title("وضعیت").Width("10%").ClientTemplate("#= IsActive ? '<span class=\"badge bg-success\">فعال</span>' : '<span class=\"badge bg-danger\">غیرفعال</span>' #").HtmlAttributes(new { style = "text-align:center;" });
                            columns.Bound(c => c.CreatedAt).Title("تاریخ ثبت").Width("12%").HtmlAttributes(new { style = "text-align:center;" });
                            columns.Command(cmd =>
                            {
                                cmd.Custom("ویرایش").Click("openEditModal").HtmlAttributes(new { @class = "btn btn-sm btn-primary" });
                                cmd.Custom("وسایل").Click("showAssets").HtmlAttributes(new { @class = "btn btn-sm btn-info" });
                                cmd.Custom("انتقال").Click("transferAssets").HtmlAttributes(new { @class = "btn btn-sm btn-warning" });
                            @*     cmd.Destroy().Text("حذف").HtmlAttributes(new { @class = "btn btn-sm btn-danger" }); *@
                            }).Title("عملیات").Width("44%").HtmlAttributes(new { style = "text-align:center;" });
                        })
                        .ToolBar(toolbar => {
                            toolbar.Search();
                            toolbar.Custom().Text("چاپ").HtmlAttributes(new { id = "printBtn", @class = "btn btn-info" });
                        })
                        .Sortable()
                        .Filterable()
                        .Pageable()
                        .Scrollable()
                        .DataSource(ds => ds
                        .Ajax()
                        .PageSize(20)
                        .Read(r => r.Action("AssestUsers_read", "Assest"))
                        .Create(c => c.Action("RegisterUser", "Assest").Data("antiForgery"))
                        .Update(u => u.Action("AssestUsers_update", "Assest").Data("antiForgery"))
                        .Destroy(d => d.Action("AssestUsers_destroy", "Assest").Data("antiForgery"))
                        .Model(m => { m.Id(f => f.Id); m.Field(f => f.Id).Editable(false); })
                        )
                        .Excel(excel => excel
                            .FileName("مالکین_اموال.xlsx")
                            .Filterable(true)
                        )
                        )
        </div>
    </div>
</div>

<!-- MODAL ویرایش -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                <h5 class="modal-title"><i class="fas fa-user-edit me-2"></i>ویرایش</h5>
                <button type="button" class="btn-close btn-close-white" data-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editId" />
                <div class="mb-3">
                    <label class="form-label fw-bold">نام</label>
                    <input type="text" id="editName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">خانوادگی</label>
                    <input type="text" id="editFamily" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">نوع</label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" id="editUser" name="editAssestUserTypes" value="0">
                        <label class="btn btn-outline-primary" for="editUser">کاربر</label>
                        <input type="radio" class="btn-check" id="editUnit" name="editAssestUserTypes" value="1">
                        <label class="btn btn-outline-primary" for="editUnit">واحد</label>
                    </div>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="editIsActive">
                    <label class="form-check-label fw-bold" for="editIsActive">فعال</label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-dismiss="modal">انصراف</button>
                <button id="saveEditBtn" class="btn btn-primary">ذخیره</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL وسایل -->
<div class="modal fade" id="assetsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg">
            <div class="modal-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                <h5 class="modal-title"><i class="fas fa-box me-2"></i>وسایل <span id="assetsUserName"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="assetsList"></div>
            </div>
            <div class="modal-footer">
                <button id="printAssetsBtn" class="btn btn-info"><i class="fas fa-print me-2"></i>پرینت</button>
                <button class="btn btn-secondary" data-dismiss="modal">بستن</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL انتقال -->
<div class="modal fade" id="transferModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg">
            <div class="modal-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                <h5 class="modal-title"><i class="fas fa-exchange-alt me-2"></i>انتقال وسایل</h5>
                <button type="button" class="btn-close btn-close-white" data-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="transferFromUserId" />
                <div class="alert alert-info mb-3"><strong>از:</strong> <span id="transferFromName"></span></div>
                <div class="mb-3">
                    <label class="form-label fw-bold">وسایل:</label>
                    <div id="transferAssetsList" style="max-height: 250px; overflow-y: auto; border: 1px solid #ddd; padding: 10px; border-radius: 5px;"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">به:</label>
                    <select id="transferToUserId" class="form-control"></select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-dismiss="modal">انصراف</button>
                <button id="confirmTransferBtn" class="btn btn-primary">تایید</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function antiForgery() {
            return { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() };
        }

        function showAlert(msg, type = 'success') {
            $("#alertContainer").html(`<div class="alert alert-${type} alert-dismissible fade show"><i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>${msg}<button type="button" class="close" data-dismiss="alert">&times;</button></div>`);
            setTimeout(() => $("#alertContainer .alert").alert('close'), 4000);
        }

        let grid;

        $(document).ready(function () {
            grid = $("#assestUserGrid").data("kendoGrid");
            
            grid.dataSource.bind("requestEnd", function (e) {
                if (e.type === "create") {
                    showAlert("ثبت با موفقیت انجام شد", "success");
                    clearForm();
                }
                if (e.type === "update") showAlert("ویرایش با موفقیت انجام شد", "success");
                if (e.type === "destroy") showAlert("حذف با موفقیت انجام شد", "success");
            });
        });

        $("#btnRegister").click(function () {
            grid.dataSource.add({
                Name: $("#Name").val(),
                Family: $("#Family").val(),
                AssestUserTypes: parseInt($("input[name='AssestUserTypes']:checked").val()),
                IsActive: true
            });
            grid.dataSource.sync();
        });

        function openEditModal(e) {
            e.preventDefault();
            let item = grid.dataItem($(e.currentTarget).closest("tr"));
            if (!item) { showAlert("خطا", "danger"); return; }
            $("#editId").val(item.Id);
            $("#editName").val(item.Name);
            $("#editFamily").val(item.Family);
            $("input[name='editAssestUserTypes'][value='" + item.AssestUserTypes + "']").prop("checked", true);
            $("#editIsActive").prop("checked", item.IsActive);
            $("#editModal").modal("show");
        }

        function clearForm() {
            $("#Name, #Family").val("");
            $("input[name='AssestUserTypes'][value='0']").prop("checked", true);
        }

        $("#saveEditBtn").click(function () {
            let id = parseInt($("#editId").val());
            let item = grid.dataSource.get(id);
            if (!item) { showAlert("رکورد یافت نشد", "danger"); return; }
            item.set("Name", $("#editName").val());
            item.set("Family", $("#editFamily").val());
            item.set("AssestUserTypes", parseInt($("input[name='editAssestUserTypes']:checked").val()));
            item.set("IsActive", $("#editIsActive").is(":checked"));
            $("#editModal").modal("hide");
            grid.dataSource.sync();
        });

        function showAssets(e) {
            e.preventDefault();
            let item = grid.dataItem($(e.currentTarget).closest("tr"));
            if (!item) return;
            window.location.href = '/Assest/UserAssets?userId=' + item.Id + '&userName=' + encodeURIComponent(item.Name + ' ' + item.Family);
        }

        $("#printAssetsBtn").click(function () { window.print(); });

        function transferAssets(e) {
            e.preventDefault();
            let item = grid.dataItem($(e.currentTarget).closest("tr"));
            if (!item) return;
            window.location.href = '/Assest/TransferAssets?userId=' + item.Id + '&userName=' + encodeURIComponent(item.Name + ' ' + item.Family);
        }

        $("#confirmTransferBtn").click(function () {
            let fromUserId = parseInt($("#transferFromUserId").val());
            let toUserId = parseInt($("#transferToUserId").val());
            if (!toUserId) { showAlert("انتخاب کنید", "warning"); return; }
            if (confirm("تایید؟")) {
                $.ajax({
                    url: "/Assest/TransferAssets",
                    type: "POST",
                    data: { fromUserId: fromUserId, toUserId: toUserId, __RequestVerificationToken: antiForgery().__RequestVerificationToken },
                    success: function (response) {
                        if (response.success) {
                            showAlert(response.message, "success");
                            $("#transferModal").modal("hide");
                            grid.dataSource.read();
                        } else {
                            showAlert(response.message, "danger");
                        }
                    }
                });
            }
        });
        
        $("#printBtn").click(function() {
            window.print();
        });
    </script>
}
